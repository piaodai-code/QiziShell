{
  "name": "qizi-shell",
  "version": "0.1.4",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "restart": "bash scripts/restart-dev.sh",
    "build": "electron-builder --mac --publish never",
    "ship": "bash scripts/ship.sh",
    "release": "bash scripts/release-mac.sh"
  },
  "build": {
    "appId": "com.qizi.shell",
    "productName": "QiziShell",
    "icon": "build/icon.png",
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity",
      "identity": null,
      "extendInfo": {
        "NSMicrophoneUsageDescription": "启孜 Shell 需要访问麦克风，用于语音转文字与设置中的识别测试。"
      }
    },
    "files": [
      "main.js",
      "preload.js",
      "gateway-ws.js",
      "tls-policy.js",
      "export-html.js",
      "stt-manager.js",
      "device-identity.js",
      "device-auth-store.js",
      "device-auth-payload.js",
      "index.html",
      "about.html",
      "about.js",
      "about.css",
      "style.css",
      "app.js",
      "message-time.js",
      "marked.min.js",
      "dompurify.min.js",
      "assets/icons/**",
      "assets/about-icon.png",
      "tray-icon.png"
    ]
  },
  "devDependencies": {
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "dompurify": "^3.4.9",
    "isomorphic-dompurify": "^3.16.0",
    "marked": "^18.0.5",
    "tmp-promise": "^3.0.3",
    "ws": "^8.21.0"
  }
}
